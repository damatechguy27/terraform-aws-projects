# Backend Configuration Template
# Copy this to your environment directory and customize

terraform {
  backend "s3" {
    bucket         = "PROJECT_NAME-terraform-state"
    key            = "eks/BRANCH_NAME/ENVIRONMENT/terraform.tfstate"
    region         = "AWS_REGION"
    dynamodb_table = "PROJECT_NAME-terraform-locks"
    encrypt        = true
  }
}

